<!-- @copied from https://blog.csdn.net/xu_san_duo/article/details/80364600 -->
<!-- @copied from https://www.iteye.com/blog/cgi-bin-2395647 -->

<configuration scan="true" scanPeriod="10 seconds">
    <contextName>logback</contextName>

    <!-- nameзҡ„еҖјжҳҜеҸҳйҮҸзҡ„еҗҚз§°пјҢvalueзҡ„еҖјж—¶еҸҳйҮҸе®ҡд№үзҡ„еҖјгҖӮйҖҡиҝҮе®ҡд№үзҡ„еҖјдјҡиў«жҸ’е…ҘеҲ°loggerдёҠдёӢж–ҮдёӯгҖӮе®ҡд№үеҗҺпјҢеҸҜд»ҘдҪҝвҖң${}вҖқжқҘдҪҝз”ЁеҸҳйҮҸгҖӮ -->
    <property name="log.path" value="logs/xtream-codec-server-reactive-debug-udp"/>

    <!--0. ж—Ҙеҝ—ж јејҸе’ҢйўңиүІжёІжҹ“ -->
    <!-- еҪ©иүІж—Ҙеҝ—дҫқиө–зҡ„жёІжҹ“зұ» -->
    <!-- <conversionRule conversionWord="clr" converterClass="org.springframework.boot.logging.logback.ColorConverter"/> -->
    <!-- <conversionRule conversionWord="wex" converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/> -->
    <!-- <conversionRule conversionWord="wEx" converterClass="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/> -->
    <!-- еҪ©иүІж—Ҙеҝ—ж јејҸ -->
    <property name="CONSOLE_LOG_PATTERN"
              value="${CONSOLE_LOG_PATTERN:-%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}:%L){cyan} %clr(-){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}}"/>
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50}:%L - %msg%n"/>

    <!--1. иҫ“еҮәеҲ°жҺ§еҲ¶еҸ°-->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- <Pattern>${CONSOLE_LOG_PATTERN}</Pattern> -->
            <Pattern>${FILE_LOG_PATTERN}</Pattern>
            <!-- и®ҫзҪ®еӯ—з¬ҰйӣҶ -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--2. иҫ“еҮәеҲ°ж–ҮжЎЈ-->
    <!-- 2.1 levelдёә DEBUG ж—Ҙеҝ—пјҢж—¶й—ҙж»ҡеҠЁиҫ“еҮә  -->
    <appender name="DEBUG_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/debug.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/debug-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each file should be at most 100MB, keep 2 days worth of history, but at most 2GB -->
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>2</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>debug</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- 2.2 levelдёә INFO ж—Ҙеҝ—пјҢж—¶й—ҙж»ҡеҠЁиҫ“еҮә  -->
    <appender name="INFO_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/info.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/info-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each file should be at most 100MB, keep 2 days worth of history, but at most 2GB -->
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>2</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>info</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- 2.3 levelдёә WARN ж—Ҙеҝ—пјҢж—¶й—ҙж»ҡеҠЁиҫ“еҮә  -->
    <appender name="WARN_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/warn.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset> <!-- жӯӨеӨ„и®ҫзҪ®еӯ—з¬ҰйӣҶ -->
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/warn-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each file should be at most 100MB, keep 2 days worth of history, but at most 2GB -->
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>2</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>warn</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- 2.4 levelдёә ERROR ж—Ҙеҝ—пјҢж—¶й—ҙж»ҡеҠЁиҫ“еҮә  -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/error.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset> <!-- жӯӨеӨ„и®ҫзҪ®еӯ—з¬ҰйӣҶ -->
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/error-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each file should be at most 100MB, keep 2 days worth of history, but at most 2GB -->
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>2</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <logger name="io.github.hylexus.xtream.codec.common.bean.impl.MapBeanPropertyMetadata" level="debug"/>

    <root level="info">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="DEBUG_FILE"/>
        <appender-ref ref="INFO_FILE"/>
        <appender-ref ref="WARN_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
